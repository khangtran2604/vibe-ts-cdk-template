import * as cdk from "aws-cdk-lib";
import * as dynamodb from "aws-cdk-lib/aws-dynamodb";
// @feature:rds import * as ec2 from "aws-cdk-lib/aws-ec2";
// @feature:rds import * as rds from "aws-cdk-lib/aws-rds";
import type { Construct } from "constructs";
import { ServiceStack, type ServiceStackProps } from "../base-stack";

/**
 * DatabaseStack — provisions the data tier for {{projectName}}.
 *
 * Resources created (always):
 * - DynamoDB Users table: single-table design with pk (HASH) + sk (RANGE)
 *   and a GSI on email (gsi1pk/gsi1sk) for email-based lookups.
 *   Billing: PAY_PER_REQUEST (on-demand) — no capacity planning required.
 *
 * Resources created when the `rds` feature is enabled:
 * - VPC: isolated network for the Aurora cluster (2 AZs, no NAT gateway)
 * - Aurora Serverless v2 cluster: PostgreSQL-compatible, scales between
 *   0.5 and 4 ACUs and auto-pauses after 5 minutes of inactivity.
 *
 * Removal policy:
 * - dev stage:  DESTROY — tables/clusters are deleted with the stack
 * - other stages: RETAIN — protects production data from accidental deletion
 *
 * Exported properties (consumed by service stacks):
 * - `usersTable`          — DynamoDB table construct reference
 * - `usersTableName`      — physical table name for Lambda env vars
 * - `usersTableArn`       — table ARN for IAM grants
 */
export class DatabaseStack extends ServiceStack {
  /** DynamoDB Users table — grant read/write access to service Lambdas */
  public readonly usersTable: dynamodb.Table;
  /** Physical DynamoDB table name — set as USERS_TABLE_NAME env var in Lambdas */
  public readonly usersTableName: string;
  /** ARN of the Users table — use for IAM policy grants */
  public readonly usersTableArn: string;

  constructor(scope: Construct, id: string, props: ServiceStackProps) {
    super(scope, id, props);

    // -------------------------------------------------------------------------
    // DynamoDB Users table — single-table design with pk/sk key schema
    //
    // Key schema:
    //   pk (HASH)  — entity prefix + ID, e.g. "USER#<uuid>"
    //   sk (RANGE) — metadata suffix, e.g. "PROFILE#<uuid>"
    //
    // GSI (EmailIndex):
    //   gsi1pk (HASH)  — "EMAIL#<email>"
    //   gsi1sk (RANGE) — "USER#<uuid>"
    //
    // Billing mode: PAY_PER_REQUEST avoids capacity planning and scales to
    // zero — ideal for dev/staging and bursty production workloads.
    //
    // pointInTimeRecovery is enabled in non-dev stages for data protection.
    // -------------------------------------------------------------------------
    this.usersTable = new dynamodb.Table(this, "UsersTable", {
      tableName: this.resourceName("{{projectName}}-users"),
      partitionKey: {
        name: "pk",
        type: dynamodb.AttributeType.STRING,
      },
      sortKey: {
        name: "sk",
        type: dynamodb.AttributeType.STRING,
      },
      billingMode: dynamodb.BillingMode.PAY_PER_REQUEST,
      // Protect data in non-dev stages — cannot be restored if DESTROY deletes
      // the table.  Keep this true in staging/prod.
      pointInTimeRecovery: !this.config.isDev,
      // Stream records to enable event-driven patterns (e.g. search indexing,
      // audit logs).  Disabled by default — uncomment if needed.
      // stream: dynamodb.StreamViewType.NEW_AND_OLD_IMAGES,
      removalPolicy: this.removalPolicy,
    });

    // GSI: look up users by email address
    this.usersTable.addGlobalSecondaryIndex({
      indexName: "EmailIndex",
      partitionKey: {
        name: "gsi1pk",
        type: dynamodb.AttributeType.STRING,
      },
      sortKey: {
        name: "gsi1sk",
        type: dynamodb.AttributeType.STRING,
      },
      projectionType: dynamodb.ProjectionType.ALL,
    });

    this.usersTableName = this.usersTable.tableName;
    this.usersTableArn = this.usersTable.tableArn;

    // -------------------------------------------------------------------------
    // DynamoDB outputs — consumed by service stacks and CI/CD pipelines
    // -------------------------------------------------------------------------

    new cdk.CfnOutput(this, "UsersTableName", {
      value: this.usersTable.tableName,
      description: "DynamoDB Users table name — set as USERS_TABLE_NAME in Lambda env",
      exportName: `{{projectName}}-UsersTableName-${this.stage}`,
    });

    new cdk.CfnOutput(this, "UsersTableArn", {
      value: this.usersTable.tableArn,
      description: "DynamoDB Users table ARN",
      exportName: `{{projectName}}-UsersTableArn-${this.stage}`,
    });

    // =========================================================================
    // RDS Aurora Serverless v2 (optional — enabled by the --rds flag)
    // =========================================================================

    // @feature:rds // -----------------------------------------------------------------------
    // @feature:rds // VPC for the Aurora cluster
    // @feature:rds //
    // @feature:rds // Uses only isolated subnets (no internet access) — the Aurora cluster
    // @feature:rds // should only be reachable from Lambda functions inside the same VPC.
    // @feature:rds // NAT gateway is intentionally omitted to minimise cost; if Lambdas need
    // @feature:rds // internet access (e.g. for external API calls) add a NAT gateway or
    // @feature:rds // configure VPC endpoints for the AWS services you use.
    // @feature:rds // -----------------------------------------------------------------------
