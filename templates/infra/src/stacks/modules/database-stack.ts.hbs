    // @feature:rds   maxAzs: 2,
    // @feature:rds   // No NAT gateway — Lambdas in isolated subnets + VPC endpoints for AWS APIs
    // @feature:rds   natGateways: 0,
    // @feature:rds   subnetConfiguration: [
    // @feature:rds     {
    // @feature:rds       name: "isolated",
    // @feature:rds       subnetType: ec2.SubnetType.PRIVATE_ISOLATED,
    // @feature:rds       cidrMask: 24,
    // @feature:rds     },
    // @feature:rds   ],
    // @feature:rds });

    // @feature:rds // Security group for the Aurora cluster — only allows PostgreSQL port from
    // @feature:rds // within the VPC (Lambda functions must be in the same VPC to connect).
    // @feature:rds const dbSecurityGroup = new ec2.SecurityGroup(this, "DbSecurityGroup", {
    // @feature:rds   vpc,
    // @feature:rds   securityGroupName: this.resourceName("{{projectName}}-db-sg"),
    // @feature:rds   description: "Allow PostgreSQL access from within the VPC",
    // @feature:rds   allowAllOutbound: false,
    // @feature:rds });

    // @feature:rds dbSecurityGroup.addIngressRule(
    // @feature:rds   ec2.Peer.ipv4(vpc.vpcCidrBlock),
    // @feature:rds   ec2.Port.tcp(5432),
    // @feature:rds   "Allow PostgreSQL from within VPC"
    // @feature:rds );

    // @feature:rds // -----------------------------------------------------------------------
    // @feature:rds // Aurora Serverless v2 cluster (PostgreSQL-compatible)
    // @feature:rds //
    // @feature:rds // Capacity: 0.5–4 ACUs.  Aurora pauses the cluster after 5 minutes of
    // @feature:rds // inactivity (idle cost = $0).  First query after a pause has a cold-start
    // @feature:rds // latency of ~5 s — acceptable for low-traffic dev/staging environments.
    // @feature:rds //
    // @feature:rds // For production workloads disable auto-pause and raise minCapacity to 1+
    // @feature:rds // to avoid cold starts: set minCapacity: 1, autoPause: false.
    // @feature:rds // -----------------------------------------------------------------------
    // @feature:rds const dbCluster = new rds.DatabaseCluster(this, "AuroraCluster", {
    // @feature:rds   clusterIdentifier: this.resourceName("{{projectName}}-aurora"),
    // @feature:rds   engine: rds.DatabaseClusterEngine.auroraPostgres({
    // @feature:rds     version: rds.AuroraPostgresEngineVersion.VER_16_4,
    // @feature:rds   }),
    // @feature:rds   // Serverless v2 writer instance — scales capacity automatically
    // @feature:rds   writer: rds.ClusterInstance.serverlessV2("writer", {
    // @feature:rds     publiclyAccessible: false,
    // @feature:rds   }),
    // @feature:rds   serverlessV2MinCapacity: 0.5,
    // @feature:rds   serverlessV2MaxCapacity: 4,
    // @feature:rds   vpc,
    // @feature:rds   vpcSubnets: { subnetType: ec2.SubnetType.PRIVATE_ISOLATED },
