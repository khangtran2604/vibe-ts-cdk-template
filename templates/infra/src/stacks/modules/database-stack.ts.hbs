    // @feature:rds   },
    // @feature:rds   removalPolicy: this.removalPolicy,
    // @feature:rds   // Deletion protection prevents accidental teardown in staging/prod
    // @feature:rds   deletionProtection: !this.config.isDev,
    // @feature:rds });

    // @feature:rds // -----------------------------------------------------------------------
    // @feature:rds // RDS outputs — consumed by service Lambdas and CI/CD pipelines
    // @feature:rds // -----------------------------------------------------------------------

    // @feature:rds new cdk.CfnOutput(this, "AuroraClusterEndpoint", {
    // @feature:rds   value: dbCluster.clusterEndpoint.hostname,
    // @feature:rds   description: "Aurora cluster writer endpoint hostname",
    // @feature:rds   exportName: `{{projectName}}-AuroraClusterEndpoint-${this.stage}`,
    // @feature:rds });

    // @feature:rds new cdk.CfnOutput(this, "AuroraClusterArn", {
    // @feature:rds   value: dbCluster.clusterArn,
    // @feature:rds   description: "Aurora cluster ARN",
    // @feature:rds   exportName: `{{projectName}}-AuroraClusterArn-${this.stage}`,
    // @feature:rds });

    // @feature:rds new cdk.CfnOutput(this, "AuroraCredentialsSecretArn", {
    // @feature:rds   value: dbCluster.secret!.secretArn,
    // @feature:rds   description: "ARN of the Secrets Manager secret containing Aurora credentials",
    // @feature:rds   exportName: `{{projectName}}-AuroraCredentialsSecretArn-${this.stage}`,
    // @feature:rds });
  }
}
