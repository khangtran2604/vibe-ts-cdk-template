/**
 * OpenAPI route registration for the {{moduleName}} service.
 *
 * This module creates an `OpenAPIRegistry` and registers all 5 CRUD endpoints
 * together with their request/response schemas.  The registry is consumed by
 * the spec-generation script to produce the final `openapi.json` artifact.
 *
 * Endpoints registered:
 *   POST   /{{moduleName}}          — create a {{entityNameLower}}
 *   GET    /{{moduleName}}          — list {{moduleName}} (cursor pagination)
 *   GET    /{{moduleName}}/{id}     — get a single {{entityNameLower}}
 *   PUT    /{{moduleName}}/{id}     — update a {{entityNameLower}} (partial)
 *   DELETE /{{moduleName}}/{id}     — delete a {{entityNameLower}}
 */

import { z } from "zod";
import {
  OpenAPIRegistry,
  extendZodWithOpenApi,
} from "@asteasolutions/zod-to-openapi";

import {
  {{EntityName}}Schema,
  Create{{EntityName}}BodySchema,
  Update{{EntityName}}BodySchema,
} from "./schemas/index.js";
import {
  ApiResponseSchema,
  ApiErrorResponseSchema,
  PaginatedResultSchema,
} from "@{{projectName}}/shared-types";

// Enable the `.openapi()` method on every Zod type.  Idempotent — safe to call
// in every module that constructs schemas.
extendZodWithOpenApi(z);

// ---------------------------------------------------------------------------
// Registry
// ---------------------------------------------------------------------------

export const registry = new OpenAPIRegistry();

// ---------------------------------------------------------------------------
// Schema registrations
// ---------------------------------------------------------------------------

// Register entity schemas so the generator emits them under #/components/schemas.
registry.register("{{EntityName}}", {{EntityName}}Schema);
registry.register("Create{{EntityName}}Body", Create{{EntityName}}BodySchema);
registry.register("Update{{EntityName}}Body", Update{{EntityName}}BodySchema);

// ---------------------------------------------------------------------------
// Shared inline schemas
// ---------------------------------------------------------------------------

/** Reusable `{id}` path parameter schema. */
const idPathParam = z.string().uuid().openapi({
  param: { name: "id", in: "path" },
  example: "d290f1ee-6c54-4b01-90e6-d701748f0851",
});

// ---------------------------------------------------------------------------
// POST /{{moduleName}} — create a {{entityNameLower}}
// ---------------------------------------------------------------------------

registry.registerPath({
  method: "post",
  path: "/{{moduleName}}",
  summary: "Create a {{entityNameLower}}",
  description: "Creates a new {{entityNameLower}} and persists it.  Returns the created {{entityNameLower}}.",
  tags: ["{{EntityName}}"],
  request: {
    body: {
      required: true,
      content: {
        "application/json": {
          schema: Create{{EntityName}}BodySchema,
        },
      },
    },
  },
  responses: {
    201: {
      description: "{{EntityName}} created successfully",
      content: {
        "application/json": {
          schema: ApiResponseSchema({{EntityName}}Schema),
        },
      },
    },
    400: {
      description: "Request body is missing, malformed JSON, or fails schema validation",
      content: {
        "application/json": {
          schema: ApiErrorResponseSchema,
        },
      },
    },
  },
});

// ---------------------------------------------------------------------------
// GET /{{moduleName}} — list {{moduleName}} with cursor pagination
// ---------------------------------------------------------------------------

registry.registerPath({
  method: "get",
  path: "/{{moduleName}}",
  summary: "List {{moduleName}}",
  description:
    "Returns a cursor-paginated list of {{moduleName}}.  Pass the `cursor` value from " +
    "the previous response to fetch the next page.",
  tags: ["{{EntityName}}"],
  request: {
    query: z.object({
      cursor: z
        .string()
        .optional()
        .openapi({
          description:
            "Opaque pagination cursor returned by the previous page response.",
          example: "d290f1ee-6c54-4b01-90e6-d701748f0851",
        }),
      limit: z
        .number()
        .int()
        .min(1)
        .max(100)
        .default(20)
        .optional()
        .openapi({
          description: "Maximum number of {{moduleName}} to return (1–100).  Defaults to 20.",
          example: 20,
        }),
    }),
  },
  responses: {
    200: {
      description: "Paginated list of {{moduleName}}",
      content: {
        "application/json": {
          schema: ApiResponseSchema(PaginatedResultSchema({{EntityName}}Schema)),
        },
      },
    },
  },
});

// ---------------------------------------------------------------------------
// GET /{{moduleName}}/{id} — get a single {{entityNameLower}}
// ---------------------------------------------------------------------------

registry.registerPath({
  method: "get",
  path: "/{{moduleName}}/{id}",
  summary: "Get a {{entityNameLower}}",
  description: "Retrieves a single {{entityNameLower}} by its UUID.",
  tags: ["{{EntityName}}"],
  request: {
    params: z.object({ id: idPathParam }),
  },
  responses: {
    200: {
      description: "{{EntityName}} found",
      content: {
        "application/json": {
          schema: ApiResponseSchema({{EntityName}}Schema),
        },
      },
    },
    404: {
      description: "{{EntityName}} not found",
      content: {
        "application/json": {
          schema: ApiErrorResponseSchema,
        },
      },
    },
  },
});

// ---------------------------------------------------------------------------
// PUT /{{moduleName}}/{id} — update a {{entityNameLower}} (partial)
// ---------------------------------------------------------------------------

registry.registerPath({
  method: "put",
  path: "/{{moduleName}}/{id}",
  summary: "Update a {{entityNameLower}}",
  description:
    "Applies a partial update to an existing {{entityNameLower}}.  Only the fields supplied " +
    "in the request body are changed.",
  tags: ["{{EntityName}}"],
  request: {
    params: z.object({ id: idPathParam }),
    body: {
      required: true,
      content: {
        "application/json": {
          schema: Update{{EntityName}}BodySchema,
        },
      },
    },
  },
  responses: {
    200: {
      description: "{{EntityName}} updated successfully",
      content: {
        "application/json": {
          schema: ApiResponseSchema({{EntityName}}Schema),
        },
      },
    },
    400: {
      description: "Request body is missing, malformed JSON, or fails schema validation",
      content: {
        "application/json": {
          schema: ApiErrorResponseSchema,
        },
      },
    },
    404: {
      description: "{{EntityName}} not found",
      content: {
        "application/json": {
          schema: ApiErrorResponseSchema,
        },
      },
    },
  },
});

// ---------------------------------------------------------------------------
// DELETE /{{moduleName}}/{id} — delete a {{entityNameLower}}
// ---------------------------------------------------------------------------

registry.registerPath({
  method: "delete",
  path: "/{{moduleName}}/{id}",
  summary: "Delete a {{entityNameLower}}",
  description: "Removes a {{entityNameLower}} permanently.  Returns 204 No Content on success.",
  tags: ["{{EntityName}}"],
  request: {
    params: z.object({ id: idPathParam }),
  },
  responses: {
    204: {
      description: "{{EntityName}} deleted — no response body",
    },
    404: {
      description: "{{EntityName}} not found",
      content: {
        "application/json": {
          schema: ApiErrorResponseSchema,
        },
      },
    },
  },
});
