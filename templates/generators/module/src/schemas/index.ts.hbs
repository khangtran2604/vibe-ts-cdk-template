/**
 * Zod schemas for the {{moduleName}} microservice.
 *
 * These schemas serve a dual purpose:
 *   1. Runtime validation of API payloads (both inbound and outbound).
 *   2. OpenAPI document generation via `@asteasolutions/zod-to-openapi`.
 *
 * Import these in Lambda handlers and OpenAPI registry code.
 */

import { z } from "zod";
import { extendZodWithOpenApi } from "@asteasolutions/zod-to-openapi";

// Enable the `.openapi()` method on every Zod type.  Idempotent — safe to call
// in every schema module regardless of import order.
extendZodWithOpenApi(z);

// ---------------------------------------------------------------------------
// Domain model
// ---------------------------------------------------------------------------

/**
 * Full {{entityNameLower}} record schema, including server-generated fields.
 *
 * `id` is a UUID v4 generated by `crypto.randomUUID()` at creation time.
 * `createdAt` and `updatedAt` are ISO-8601 strings set automatically.
 */
export const {{EntityName}}Schema = z
  .object({
    /** Unique identifier (UUID v4). */
    id: z.iso.uuid(),
    /** Human-readable name for the {{entityNameLower}}. */
    name: z.string().min(1),
    /** ISO-8601 creation timestamp. */
    createdAt: z.iso.datetime(),
    /** ISO-8601 last-updated timestamp. */
    updatedAt: z.iso.datetime(),
  })
  .openapi("{{EntityName}}");

// ---------------------------------------------------------------------------
// Request bodies
// ---------------------------------------------------------------------------

/**
 * Request body schema for creating a new {{entityNameLower}}.
 *
 * The `id`, `createdAt`, and `updatedAt` fields are server-generated and must
 * not be provided by the caller.
 */
export const Create{{EntityName}}BodySchema = z
  .object({
    /** Human-readable name for the {{entityNameLower}}. */
    name: z.string().min(1),
  })
  .openapi("Create{{EntityName}}Body");

/**
 * Request body schema for updating an existing {{entityNameLower}}.
 *
 * All fields are optional — only the provided fields are changed.
 */
export const Update{{EntityName}}BodySchema = z
  .object({
    /** Human-readable name for the {{entityNameLower}}. */
    name: z.string().min(1).optional(),
  })
  .openapi("Update{{EntityName}}Body");

// ---------------------------------------------------------------------------
// Inferred TypeScript types
// ---------------------------------------------------------------------------

/** Full {{entityNameLower}} record, including server-generated fields. */
export type {{EntityName}} = z.infer<typeof {{EntityName}}Schema>;

/** Fields accepted when creating a new {{entityNameLower}}. */
export type Create{{EntityName}}Body = z.infer<typeof Create{{EntityName}}BodySchema>;

/** Fields accepted when updating an existing {{entityNameLower}}. */
export type Update{{EntityName}}Body = z.infer<typeof Update{{EntityName}}BodySchema>;
