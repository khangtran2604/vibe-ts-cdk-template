import { describe, it, expect, beforeEach } from "vitest";
import { createMockEvent } from "@{{projectName}}/lambda-utils";
import { handler } from "../handlers/create-user.js";
import { users } from "../store.js";

// Clear the in-memory store before each test so tests are isolated.
beforeEach(() => {
  users.clear();
});

describe("create-user handler", () => {
  it("returns statusCode 201 when given a valid body", async () => {
    const event = createMockEvent({
      httpMethod: "POST",
      path: "/users",
      body: JSON.stringify({ name: "Alice", email: "alice@example.com" }),
    });

    const result = await handler(event);

    expect(result.statusCode).toBe(201);
  });

  it("returns a user object with generated id and timestamps", async () => {
    const event = createMockEvent({
      httpMethod: "POST",
      path: "/users",
      body: JSON.stringify({ name: "Bob", email: "bob@example.com" }),
    });

    const result = await handler(event);
    const body = JSON.parse(result.body) as {
      success: boolean;
      data: { id: string; name: string; email: string; createdAt: string; updatedAt: string };
    };

    expect(body.success).toBe(true);
    expect(typeof body.data.id).toBe("string");
    expect(body.data.id).toMatch(
      /^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i
    );
    expect(body.data.name).toBe("Bob");
    expect(body.data.email).toBe("bob@example.com");
    expect(typeof body.data.createdAt).toBe("string");
    expect(typeof body.data.updatedAt).toBe("string");
  });

  it("normalises email to lowercase", async () => {
    const event = createMockEvent({
      httpMethod: "POST",
      path: "/users",
      body: JSON.stringify({ name: "Carol", email: "Carol@Example.COM" }),
    });

    const result = await handler(event);
    const body = JSON.parse(result.body) as { data: { email: string } };

    expect(body.data.email).toBe("carol@example.com");
  });

  it("persists the user in the in-memory store", async () => {
    const event = createMockEvent({
      httpMethod: "POST",
      path: "/users",
      body: JSON.stringify({ name: "Dave", email: "dave@example.com" }),
    });

    const result = await handler(event);
    const body = JSON.parse(result.body) as { data: { id: string } };

    expect(users.has(body.data.id)).toBe(true);
  });

  it("sets Content-Type: application/json header", async () => {
    const event = createMockEvent({
      httpMethod: "POST",
      path: "/users",
      body: JSON.stringify({ name: "Eve", email: "eve@example.com" }),
    });

    const result = await handler(event);

    expect(result.headers?.["Content-Type"]).toBe("application/json");
  });

  it("returns 400 when body is absent", async () => {
    const event = createMockEvent({
      httpMethod: "POST",
      path: "/users",
      body: null,
    });

    const result = await handler(event);

    expect(result.statusCode).toBe(400);
    const body = JSON.parse(result.body) as { success: boolean; error: { code: string } };
    expect(body.success).toBe(false);
    expect(body.error.code).toBe("BAD_REQUEST");
  });

  it("returns 400 when name is missing", async () => {
    const event = createMockEvent({
      httpMethod: "POST",
      path: "/users",
      body: JSON.stringify({ email: "noname@example.com" }),
    });

    const result = await handler(event);

    expect(result.statusCode).toBe(400);
    const body = JSON.parse(result.body) as {
      success: boolean;
      error: { code: string; fieldErrors?: Record<string, string> };
    };
    expect(body.success).toBe(false);
    expect(body.error.code).toBe("VALIDATION_ERROR");
    expect(body.error.fieldErrors?.["name"]).toBeDefined();
  });

  it("returns 400 when email is missing", async () => {
    const event = createMockEvent({
      httpMethod: "POST",
      path: "/users",
      body: JSON.stringify({ name: "NoEmail" }),
    });

    const result = await handler(event);

    expect(result.statusCode).toBe(400);
    const body = JSON.parse(result.body) as {
      success: boolean;
      error: { code: string; fieldErrors?: Record<string, string> };
    };
    expect(body.success).toBe(false);
    expect(body.error.code).toBe("VALIDATION_ERROR");
    expect(body.error.fieldErrors?.["email"]).toBeDefined();
  });

  it("returns 400 when body is not valid JSON", async () => {
    const event = createMockEvent({
      httpMethod: "POST",
      path: "/users",
      body: "not-json{",
    });

    const result = await handler(event);

    expect(result.statusCode).toBe(400);
    const body = JSON.parse(result.body) as { error: { code: string } };
    expect(body.error.code).toBe("BAD_REQUEST");
  });
});
